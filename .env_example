# ===================================================
# Langfuse Docker Compose 环境变量配置文件示例
# ===================================================
# 请复制此文件为 .env 并根据需要修改密码值
# 所有密码都应该更改为强密码以确保安全
# openssl rand -base64 16  # 生成16字符随机密码
# openssl rand -hex 32     # 生成256位加密密钥
# ===================================================

# ===================================================
# 1. 数据库密码配置
# ===================================================

# PostgreSQL 数据库密码
# 默认: postgres (必须更改!)
POSTGRES_PASSWORD=StrongPassw0rd2024

# PostgreSQL 用户名 (可选更改)
POSTGRES_USER=postgres

# PostgreSQL 数据库名 (可选更改)
POSTGRES_DB=postgres

# ===================================================
# 2. ClickHouse 数据库密码配置
# ===================================================

# ClickHouse 用户密码
# 默认: clickhouse (必须更改!)
CLICKHOUSE_PASSWORD=Chang3M3SecurePwd

# ClickHouse 用户名 (可选更改)
CLICKHOUSE_USER=clickhouse

# ===================================================
# 3. Redis 密码配置
# ===================================================

# Redis 认证密码
# 默认: myredissecret (必须更改!)
REDIS_AUTH=R3dsS3cur3Passw0rd

# ===================================================
# 4. MinIO 对象存储密码配置
# ===================================================

# MinIO 根用户密码
# 默认: miniosecret (必须更改!)
MINIO_ROOT_PASSWORD=M1nio

# MinIO 根用户名 (可选更改)
MINIO_ROOT_USER=minio

# ===================================================
# 5. Langfuse 应用安全配置
# ===================================================

# 加密盐值 - 用于密码哈希
# 默认: mysalt (建议更改)
SALT=MyCustomSaltValue2024!Secure

# 加密密钥 - 用于数据加密 (必须生成新的!)
# 生成命令: openssl rand -hex 32
ENCRYPTION_KEY=5f8e2a9b7c1d3e0f4a6b8c9d2e1f3a5b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2

# NextAuth 密钥 - 用于身份验证
# 默认: mysecret (必须更改!)
NEXTAUTH_SECRET=N3xtAuthS3cr3tK3y!2024

# ===================================================
# 6. S3 存储访问密钥配置
# ===================================================

# S3 事件上传访问密钥ID (MinIO)
# 默认: minio (建议更改)
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio_event_user

# S3 事件上传密钥 (必须更改!)
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=${MINIO_ROOT_USER}

# S3 事件上传密钥 - 使用根用户密码
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# S3 媒体上传访问密钥ID (MinIO) - 使用根用户
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=${MINIO_ROOT_USER}

# S3 媒体上传密钥 - 使用根用户密码
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# S3 批量导出访问密钥ID (MinIO) - 使用根用户
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=${MINIO_ROOT_USER}

# S3 批量导出密钥 - 使用根用户密码
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# ===================================================
# 7. 持久化存储路径配置
# ===================================================

# PostgreSQL 数据存储路径
POSTGRES_DATA_PATH=/path-to-data/postgres

# ClickHouse 数据存储路径
CLICKHOUSE_DATA_PATH=/path-to-data/clickhouse/data

# ClickHouse 日志存储路径
CLICKHOUSE_LOGS_PATH=/path-to-data/clickhouse/logs

# MinIO 数据存储路径
MINIO_DATA_PATH=/path-to-data/minio

# Redis 数据存储路径
REDIS_DATA_PATH=/path-to-data/redis

# ===================================================
# 8. 可选配置 (根据需要启用)
# ===================================================

# 遥测启用 (true/false)
TELEMETRY_ENABLED=true

# 实验性功能启用
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# NextAuth URL
NEXTAUTH_URL=http://localhost:3000

# ===================================================
# 9. 初始化配置 (首次设置时使用)
# ===================================================

# 组织ID (必需，不然后续字段将被忽略)
LANGFUSE_INIT_ORG_ID=Org_id

# 组织名称 (可选)
LANGFUSE_INIT_ORG_NAME=My_organization

# 项目ID (可选)
LANGFUSE_INIT_PROJECT_ID=

# 项目名称 (可选)
LANGFUSE_INIT_PROJECT_NAME=My_project

# 项目公钥 (可选)
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=

# 项目密钥 (可选)
LANGFUSE_INIT_PROJECT_SECRET_KEY=

# 初始用户邮箱 (必需)
LANGFUSE_INIT_USER_EMAIL=admin@example.com

# 初始用户名称 (可选)
LANGFUSE_INIT_USER_NAME=Admin_user

# 初始用户密码 (必需)
LANGFUSE_INIT_USER_PASSWORD=AdminTempP@ss123

# ===================================================
# 10. 前端配置
# ===================================================

# OpenAI推理模型链接 (必需)
OPENAI_URL=

# OpenAI推理模型名称 (必需)
OPENAI_MODEL=

# OpenAI推理模型API_KEY (必需)
OPENAI_API_KEY=

# Langfuse项目 secret Key (必需)
LANGFUSE_SECRET_KEY=

# Langfuse项目 public Key (必需)
LANGFUSE_PUBLIC_KEY=

# Langfuse项目地址 (必需，容器名)
LANGFUSE_BASE_URL=http://langfuse-web:3000

# 检查点数据库 (必需)
POSTGRES_DB_CHECKPOINTER=deepagent_checkpointer_db

# 检查点数据库 (可选，local dev)
DATABASE_URL_CHECKPOINTER=postgresql://postgres:StrongPassw0rdi2024@localhost:5432/deepagent_checkpointer_db

# 记忆数据库名 (必需)
POSTGRES_DB_STORE=deepagent_store_db

# 记忆数据库 (可选，local dev)
DATABASE_URL_STORE=postgresql://postgres:StrongPassw0rdi2024@localhost:5432/deepagent_store_db

# 对话历史数据库名 (必需)
POSTGRES_DB_HISTORY=deepagent_history_db

# 对话历史数据库 (可选，local dev)
DATABASE_URL_HISTORY=postgresql://postgres:StrongPassw0rdi2024@localhost:5432/deepagent_store_db

# 工作区（可选，挂载）
WORKSPACE=

# For Google Search（可选）
SERPER_API_KEY=
